# Não ativar LOCAL_APP_URL aqui por defeito: o Electron tenta sempre esse URL em dev e
# falha com ERR_CONNECTION_REFUSED se o Vite não estiver a correr.
#
# Para hot-reload do menu lateral:
#   • VS Code: configuração "Electron + Vite", ou
#   • Terminal: cd local-app && yarn dev  e  cd electron && set LOCAL_APP_URL=http://localhost:3000/ && yarn electron dist/main.js
#
# LOCAL_APP_URL=http://localhost:3000
